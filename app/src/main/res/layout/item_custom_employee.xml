<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="2dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="1dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <!-- Employee Initial Accent Symbol -->
            <TextView
                android:id="@+id/tvEmpSymbol"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_order_chip"
                android:textColor="@color/order_primary"
                android:textStyle="bold"
                android:textSize="18sp"
                android:gravity="center"
                android:text="E"
                android:layout_marginEnd="16dp" />

            <!-- Info Column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <TextView
                    android:id="@+id/tvEmpNameText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="John Doe"
                    android:textColor="@color/order_text_primary"
                    android:textSize="15dp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvEmpRoleDeptText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manager • Marketing dept"
                    android:textColor="@color/order_text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="3dp" />

                <TextView
                    android:id="@+id/tvEmpSalaryText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Salary: $1,200.00"
                    android:textColor="@color/order_success_text"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:layout_marginTop="3dp" />
            </LinearLayout>

            <!-- Actions buttons side -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/btnEditRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Edit"
                    android:textColor="@color/order_primary"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:paddingVertical="4dp"
                    android:paddingHorizontal="10dp"
                    android:background="@drawable/bg_order_chip"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/btnDeleteRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Delete"
                    android:textColor="@color/order_complaint_text"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:paddingVertical="4dp"
                    android:paddingHorizontal="10dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_order_chip"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
