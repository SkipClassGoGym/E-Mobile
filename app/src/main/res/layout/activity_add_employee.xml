<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/order_screen_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Top Header Action -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New Staff Register"
                android:textColor="@color/order_text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_alignParentStart="true" />

            <Button
                android:id="@+id/btnCancelAdd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancel"
                android:textColor="@color/order_complaint_text"
                android:background="@drawable/bg_order_chip"
                app:backgroundTint="@null"
                android:layout_alignParentEnd="true" />
        </RelativeLayout>

        <!-- Form Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Form Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ENTER STAFF CREDS"
                    android:textColor="@color/order_text_secondary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- Staff ID Input -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Employee ID (Format: E00X)"
                    android:textColor="@color/order_text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/editEmpId"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_order_search"
                    android:paddingHorizontal="16dp"
                    android:hint="E004"
                    android:inputType="text"
                    android:textCursorDrawable="@null"
                    android:textColor="@color/order_text_primary"
                    android:layout_marginBottom="16dp" />

                <!-- Staff Name Input -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Full Name"
                    android:textColor="@color/order_text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/editEmpName"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_order_search"
                    android:paddingHorizontal="16dp"
                    android:hint="Le Huy Hoang"
                    android:inputType="textPersonName"
                    android:textCursorDrawable="@null"
                    android:textColor="@color/order_text_primary"
                    android:layout_marginBottom="16dp" />

                <!-- Department Spinner Selector -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Department Assigned"
                    android:textColor="@color/order_text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <Spinner
                    android:id="@+id/spEmpDept"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_order_search"
                    android:paddingHorizontal="12dp"
                    android:layout_marginBottom="16dp" />

                <!-- Work Role Input -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Role Title"
                    android:textColor="@color/order_text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/editEmpRole"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_order_search"
                    android:paddingHorizontal="16dp"
                    android:hint="Consultant"
                    android:inputType="text"
                    android:textCursorDrawable="@null"
                    android:textColor="@color/order_text_primary"
                    android:layout_marginBottom="16dp" />

                <!-- Salary Input -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Salary ($USD equivalent)"
                    android:textColor="@color/order_text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/editEmpSalary"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_order_search"
                    android:paddingHorizontal="16dp"
                    android:hint="1500.00"
                    android:inputType="numberDecimal"
                    android:textCursorDrawable="@null"
                    android:textColor="@color/order_text_primary"
                    android:layout_marginBottom="24dp" />

                <!-- Save Action Button -->
                <Button
                    android:id="@+id/btnSaveEmployee"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="SAVE EMPLOYEE PROFILE"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_order_chip_active"
                    app:backgroundTint="@null" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
