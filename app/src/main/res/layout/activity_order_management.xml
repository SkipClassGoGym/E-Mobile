<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/order_screen_bg">

    <!-- Top Action header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_order_header"
        android:orientation="vertical"
        android:padding="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sales Ledger"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_alignParentStart="true" />

            <Button
                android:id="@+id/btnBackOrder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Back"
                android:textColor="@color/order_primary"
                android:background="@drawable/bg_order_chip"
                app:backgroundTint="@null"
                android:layout_alignParentEnd="true" />
        </RelativeLayout>

        <!-- KPI Cards Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Card 1: Today's Orders -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="8dp"
                app:cardBackgroundColor="#1E293B">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Orders"
                        android:textColor="#94A3B8"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvTodayOrders"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 2: Today Revenue -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.3"
                android:layout_marginHorizontal="6dp"
                app:cardCornerRadius="8dp"
                app:cardBackgroundColor="#1E293B">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Sales Value"
                        android:textColor="#94A3B8"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvTodayRevenue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$0.00"
                        android:textColor="#38BDF8"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"
                        android:singleLine="true" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 3: Need Action -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginLeft="6dp"
                app:cardCornerRadius="8dp"
                app:cardBackgroundColor="#1E293B">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Needs Action"
                        android:textColor="#94A3B8"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvNeedAction"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#FB7185"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Date Inputs Selection Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnFromDate"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:text="From: Date"
                android:textColor="@color/order_text_primary"
                android:background="@drawable/bg_order_chip"
                android:layout_marginEnd="6dp"
                app:backgroundTint="@null"
                android:gravity="center"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnToDate"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:text="To: Date"
                android:textColor="@color/order_text_primary"
                android:background="@drawable/bg_order_chip"
                android:layout_marginLeft="6dp"
                app:backgroundTint="@null"
                android:gravity="center"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Apply / Reset Date Filter Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnFilterByDate"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="Apply Range"
                android:textColor="@color/white"
                android:background="@drawable/bg_order_chip_active"
                android:layout_marginEnd="6dp"
                app:backgroundTint="@null"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnClearDateFilter"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="Reset Filters"
                android:textColor="@color/order_primary"
                android:background="@drawable/bg_order_chip"
                android:layout_marginLeft="6dp"
                app:backgroundTint="@null"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Status Filter Menu Selector -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Orders Inventory Status"
                android:textColor="@color/order_text_primary"
                android:textStyle="bold"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnOrderStatusMenu"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="All Status ▼"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="12sp"
                android:background="@drawable/bg_order_chip_active"
                app:backgroundTint="@null"
                android:paddingHorizontal="16dp" />
        </LinearLayout>

        <!-- Orders list view -->
        <ListView
            android:id="@+id/lvOrders"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@null"
            android:dividerHeight="8dp"
            android:scrollbars="vertical"/>

    </LinearLayout>

</LinearLayout>
