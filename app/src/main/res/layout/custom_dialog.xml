<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Edit Employee Profile"
        android:textColor="@color/order_text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Name Edit -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Employee Name"
        android:textColor="@color/order_text_secondary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/dialogEditName"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/bg_order_search"
        android:paddingHorizontal="12dp"
        android:inputType="textPersonName"
        android:textColor="@color/order_text_primary"
        android:layout_marginBottom="12dp" />

    <!-- Role Edit -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Role / Designation"
        android:textColor="@color/order_text_secondary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/dialogEditRole"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/bg_order_search"
        android:paddingHorizontal="12dp"
        android:inputType="text"
        android:textColor="@color/order_text_primary"
        android:layout_marginBottom="12dp" />

    <!-- Dept Spinner Selection -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Department"
        android:textColor="@color/order_text_secondary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <Spinner
        android:id="@+id/dialogSpinnerDept"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/bg_order_search"
        android:paddingHorizontal="8dp"
        android:layout_marginBottom="12dp" />

    <!-- Salary Edit -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Salary"
        android:textColor="@color/order_text_secondary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/dialogEditSalary"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/bg_order_search"
        android:paddingHorizontal="12dp"
        android:inputType="numberDecimal"
        android:textColor="@color/order_text_primary"
        android:layout_marginBottom="24dp" />

</LinearLayout>
