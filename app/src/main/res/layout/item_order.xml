<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_order_card"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Info Column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginEnd="12dp">

            <TextView
                android:id="@+id/txtOrderSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Order Summary details"
                android:textColor="@color/order_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <!-- Status Pill container -->
        <TextView
            android:id="@+id/txtOrderStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status"
            android:textColor="@color/order_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"
            android:background="@drawable/bg_status_pending"/>

    </LinearLayout>
</LinearLayout>
